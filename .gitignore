# =============================================================================
# .gitignore — Curso Corvino Acordeon MIDI
# Salva código + curso, ignora assets pesados (binários que podem ser
# baixados separado) e arquivos temporários.
# =============================================================================

# --- ASSETS PESADOS ---
# Soundfonts (.sf2) e grooves (.mp3) versionados — necessários pro app tocar som.
# Total ~400MB. Maior arquivo 59MB (abaixo do limite GitHub de 100MB).
# Ignoramos só os arquivos .original.mp3 (backups do conversor, não usados):
app/assets/grooves/*.original.mp3

# --- BUILDS COMPILADOS ---
# Builds gerados — sempre podem ser recriados a partir do código fonte
desktop/
*/build/
*/dist/
*/target/
*.exe
*.msi
*.dll
*.so
*.dylib

# --- DEPENDÊNCIAS / CACHES ---
node_modules/
.pnp/
.pnp.js
.yarn/
.npm/
.cache/
__pycache__/
*.pyc
.pytest_cache/

# --- IDEs e EDITORES ---
.idea/
.vscode/
.fleet/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- LOGS E TEMPORÁRIOS ---
*.log
*.tmp
*.bak
*.old
*~
bash.exe.stackdump

# --- CREDENCIAIS / SECRETS ---
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# --- ZIPS E BACKUPS ANTIGOS ---
*.zip
*.rar
*.7z
*_backup/
*_old/
_extracted/
_extracted_original/
_workspace/

# --- ARQUIVOS DE TESTE DE LATÊNCIA (gerados, não-essenciais) ---
latency_test/
